# mTLS 인증서 경로 (앱인토스 콘솔에서 발급)
CLIENT_CERT_PATH=cert/public.crt
CLIENT_KEY_PATH=cert/private.key

# 사용자 데이터 복호화 (콘솔에서 이메일로 수신)
AAD_STRING=
DECRYPTION_KEY_BASE64=

# Toss OAuth API
AUTH_API_BASE=https://apps-in-toss-api.toss.im/api-partner/v1/apps-in-toss/user/oauth2

PORT=4000

# Supabase (서버 전용 — Secret Key / Service Role Key, 클라이언트에 노출 금지)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase JWT Secret (RLS 본인 userkey 검증용 — Project Settings → API → JWT Secret)
SUPABASE_JWT_SECRET=
